import api from "./api";

export const getDashboardStats =
    () =>
        api.get(
            "/admin/dashboard"
        );

export const getLowStockProducts =
    () =>
        api.get(
            "/admin/dashboard?type=low-stock"
        );

export const getRecentOrders =
    () =>
        api.get(
            "/admin/dashboard?type=recent-orders"
        );